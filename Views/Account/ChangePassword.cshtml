@{ ViewData["Title"] = "Change Password"; }

<div class="row justify-content-center">
    <div class="col-lg-5 col-md-8">
        <div class="card">
            <h5 class="fw-bold mb-4" style="color:var(--gray-700); font-size:1.05rem;">
                <i class="bi bi-key me-2" style="color:var(--blue);"></i>Change Password
            </h5>

            @if (TempData["Success"] != null)
            {
                <div class="alert-success-inline mb-4">
                    <i class="bi bi-check-circle-fill"></i>@TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert-error-inline mb-4">
                    <i class="bi bi-x-circle-fill"></i>@TempData["Error"]
                </div>
            }

            <form asp-action="ChangePassword" method="post">
                <div class="mb-3">
                    <label class="form-label-fids">Current Password <span class="required-star">*</span></label>
                    <input type="password" name="currentPassword" class="form-control-fids"
                           placeholder="Enter current password" required />
                </div>
                <div class="mb-3">
                    <label class="form-label-fids">New Password <span class="required-star">*</span></label>
                    <input type="password" name="newPassword" class="form-control-fids"
                           placeholder="Min 6 characters" required minlength="6" />
                </div>
                <div class="mb-4">
                    <label class="form-label-fids">Confirm New Password <span class="required-star">*</span></label>
                    <input type="password" name="confirmPassword" class="form-control-fids"
                           placeholder="Repeat new password" required minlength="6" />
                </div>
                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn-save">
                        <i class="bi bi-key me-1"></i>Change Password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
