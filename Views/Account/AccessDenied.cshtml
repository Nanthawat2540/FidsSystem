@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Access Denied — FIDS</title>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:'IBM Plex Sans Thai',sans-serif; background:#F4F6FB; color:#2E2E2E;
               display:flex; align-items:center; justify-content:center; height:100vh; }
        .box { text-align:center; padding:48px 40px; background:rgba(255,255,255,.88);
               border:1px solid rgba(183,202,227,.35); border-radius:20px; max-width:420px;
               box-shadow: 0 8px 30px rgba(0,0,0,.08); }
        .icon { font-size:3.5rem; margin-bottom:16px; }
        h1 { font-size:1.6rem; font-weight:700; margin-bottom:8px; }
        p { color:#5c5c6e; font-size:.95rem; margin-bottom:24px; line-height:1.6; }
        .role-badge { display:inline-block; padding:4px 14px; background:rgba(122,159,201,.11);
                      border-radius:20px; font-size:.8rem; color:#5585b8; margin-bottom:24px; }
        a { display:inline-block; padding:10px 24px; background:linear-gradient(135deg, #7a9fc9 0%, #5585b8 100%); color:#fff;
            border-radius:12px; text-decoration:none; font-weight:600; font-size:.9rem; }
        a:hover { background:#5585b8; }
    </style>
</head>
<body>
    <div class="box">
        <div class="icon">🔒</div>
        <h1>Access Denied</h1>
        <p>You don't have permission to access this page.</p>
        <div class="role-badge">Your role: @ViewBag.Role</div>
        <br />
        <a href="/Flight">← Back to Flights</a>
    </div>
</body>
</html>
