@{
    ViewData["Title"] = "Display Management";
    var s = ViewBag.Settings as Dictionary<string,string> ?? new Dictionary<string,string>();
    string V(string key, string def) => s.TryGetValue(key, out var v) ? v : def;
}

@section TopbarActions {
    <button type="submit" form="settingsForm" class="btn-save">Save</button>
}

@if (TempData["Success"] != null)
{
    <div style="background:#e8f7ee; color:#2e7d32; border-radius:8px; padding:12px 18px; margin-bottom:16px; font-size:0.9rem;">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
    </div>
}

<div class="card">
    <form id="settingsForm" asp-action="DisplaySettings" method="post">
        <!-- 1. Bag and Belt -->
        <div class="settings-section">
            <h6>1. Bag and Belt Information</h6>
            <p>Display flights scheduled to arrive within 3 hours before the current time.<br/>Remove flights from the display under these conditions:</p>

            <div class="settings-row">
                <label class="settings-label">1.1 When First Bag time is recorded, remove after 60 minutes. <span class="required-star">*</span></label>
                <div class="settings-input-wrap">
                    <input type="number" name="BagFirstBag" class="settings-input" value="@V("BagFirstBag","60")" min="0" />
                    <span class="settings-unit">Min</span>
                </div>
            </div>
            <div class="settings-row">
                <label class="settings-label">1.2 When Last Bag time is recorded, remove after 30 minutes. <span class="required-star">*</span></label>
                <div class="settings-input-wrap">
                    <input type="number" name="BagLastBag" class="settings-input" value="@V("BagLastBag","30")" min="0" />
                    <span class="settings-unit">Min</span>
                </div>
            </div>
            <div class="settings-row">
                <label class="settings-label">1.3 When ATA (Landed) is recorded but no First Bag, remove after 120 minutes. <span class="required-star">*</span></label>
                <div class="settings-input-wrap">
                    <input type="number" name="BagNoFirstBag" class="settings-input" value="@V("BagNoFirstBag","120")" min="0" />
                    <span class="settings-unit">Min</span>
                </div>
            </div>
        </div>

        <hr class="settings-divider" />

        <!-- 2. Arrival Flights -->
        <div class="settings-section">
            <h6>2. Arrival Flights Information</h6>
            <div class="settings-row">
                <label class="settings-label">Display flights scheduled to arrive within 180 minutes before the current time. <span class="required-star">*</span></label>
                <div class="settings-input-wrap">
                    <input type="number" name="ArrivalWindow" class="settings-input" value="@V("ArrivalWindow","180")" min="0" />
                    <span class="settings-unit">Min</span>
                </div>
            </div>
            <p style="font-size:0.85rem; color:#7e8299; margin-top:8px;">Remove flights under these conditions:</p>
            <div class="settings-row">
                <label class="settings-label">2.1 When First Bag time is recorded, remove after 0 minutes. <span class="required-star">*</span></label>
                <div class="settings-input-wrap">
                    <input type="number" name="ArrFirstBag" class="settings-input" value="@V("ArrFirstBag","0")" min="0" />
                    <span class="settings-unit">Min</span>
                </div>
            </div>
            <div class="settings-row">
                <label class="settings-label">2.2 When Last Bag time is recorded, remove after 30 minutes. <span class="required-star">*</span></label>
                <div class="settings-input-wrap">
                    <input type="number" name="ArrLastBag" class="settings-input" value="@V("ArrLastBag","30")" min="0" />
                    <span class="settings-unit">Min</span>
                </div>
            </div>
            <div class="settings-row">
                <label class="settings-label">2.3 When ATA (Landed) is recorded but no First Bag, remove after 120 minutes.</label>
                <div class="settings-input-wrap">
                    <input type="number" name="ArrNoFirstBag" class="settings-input" value="@V("ArrNoFirstBag","120")" min="0" />
                    <span class="settings-unit">Min</span>
                </div>
            </div>
            <div class="settings-row" style="margin-top:16px;">
                <label class="settings-label" style="font-weight:600; color:#3f4254;">Display status remarks:</label>
                <div style="font-size:0.85rem; color:#7e8299; margin-top:6px; line-height:2;">
                    2.2.1 Confirmed: When ETA is sent to the AODB system.<br/>
                    2.2.2 Landed: When ATA is sent to the AODB system.<br/>
                    2.2.3 Delayed: When ETA exceeds STA by more than 180 minutes.
                    <span class="required-star">*</span>
                </div>
                <div class="settings-input-wrap" style="margin-top:10px;">
                    <input type="number" name="DelayThreshold" class="settings-input" value="@V("DelayThreshold","180")" min="0" />
                    <span class="settings-unit">Min</span>
                </div>
            </div>
        </div>

        <hr class="settings-divider" />

        <!-- 0. Airport Identity -->
        <div class="settings-section">
            <h6>0. Airport Information</h6>
            <div class="settings-row">
                <label class="settings-label">Airport Name (Thai)</label>
                <div class="settings-input-wrap" style="flex:1; max-width:360px;">
                    <input type="text" name="AirportNameTH" class="settings-input"
                           style="width:100%;" value="@V("AirportNameTH","ท่าอากาศยานนานาชาติสุราษฎร์ธานี")" />
                </div>
            </div>
            <div class="settings-row">
                <label class="settings-label">Airport Name (English)</label>
                <div class="settings-input-wrap" style="flex:1; max-width:360px;">
                    <input type="text" name="AirportNameEN" class="settings-input"
                           style="width:100%;" value="@V("AirportNameEN","Surat Thani Airport")" />
                </div>
            </div>
            <div class="settings-row">
                <label class="settings-label">IATA Code</label>
                <div class="settings-input-wrap">
                    <input type="text" name="AirportIATA" class="settings-input"
                           style="width:80px;" maxlength="3" value="@V("AirportIATA","URT")" />
                </div>
            </div>
        </div>

        <hr class="settings-divider" />

        <!-- 3. Departure Flights -->
        <div class="settings-section">
            <h6>3. Departure Flights Information</h6>
            <div class="settings-row">
                <label class="settings-label">Display flights scheduled to depart within 180 minutes after the current time. <span class="required-star">*</span></label>
                <div class="settings-input-wrap">
                    <input type="number" name="DepWindow" class="settings-input" value="@V("DepWindow","180")" min="0" />
                    <span class="settings-unit">Min</span>
                </div>
            </div>
            <div class="settings-row">
                <label class="settings-label">Remove flights when departed for more than 30 minutes. <span class="required-star">*</span></label>
                <div class="settings-input-wrap">
                    <input type="number" name="DepRemove" class="settings-input" value="@V("DepRemove","30")" min="0" />
                    <span class="settings-unit">Min</span>
                </div>
            </div>
        </div>
    </form>
</div>
