@model List<FidsSystem.Models.AdminUser>
@using FidsSystem.Models
@{
    ViewData["Title"] = "User Management";
    var airlines = ViewBag.Airlines as IEnumerable<AirlineLogo> ?? [];
}

@section TopbarActions {
    <button class="btn-add" onclick="openAddModal()">
        <i class="bi bi-person-plus-fill"></i> Add User
    </button>
}

@if (TempData["Success"] != null)
{
    <div class="alert-success-inline"><i class="bi bi-check-circle-fill"></i>@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-error-inline"><i class="bi bi-x-circle-fill"></i>@TempData["Error"]</div>
}

<div class="card">
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>User</th>
                    <th style="width:14%;">Role</th>
                    <th style="width:14%;">Airline</th>
                    <th style="width:12%;">Status</th>
                    <th style="width:16%; text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var roleColor = item.Role switch {
                        Roles.Admin   => "#EF4444",
                        Roles.Staff   => "#1A6BFA",
                        Roles.Airline => "#10B981",
                        _             => "#b5b5c3"
                    };
                    var roleIcon = item.Role switch {
                        Roles.Admin   => "bi-shield-fill",
                        Roles.Staff   => "bi-person-badge-fill",
                        Roles.Airline => "bi-airplane-fill",
                        _             => "bi-person"
                    };
                    <tr>
                        <td>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <div style="width:36px; height:36px; border-radius:50%; background:var(--card-bg);
                                            border:2px solid @roleColor; display:flex; align-items:center;
                                            justify-content:center; font-weight:700; color:@roleColor; font-size:.85rem;">
                                    @item.Username.Substring(0,1).ToUpper()
                                </div>
                                <div>
                                    <div class="fw-600">@item.Username</div>
                                    <div style="font-size:.75rem; color:#7e8299;">ID: @item.Id</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span style="background:rgba(0,0,0,.2); border:1px solid @roleColor; color:@roleColor;
                                         padding:3px 10px; border-radius:20px; font-size:.75rem; font-weight:700;">
                                <i class="bi @roleIcon me-1"></i>@item.Role
                            </span>
                        </td>
                        <td style="color:#7e8299; font-size:.85rem;">
                            @if (!string.IsNullOrEmpty(item.AirlineCode))
                            {
                                <span style="background:var(--blue-light); color:var(--blue-dark); padding:2px 10px;
                                             border-radius:12px; font-size:.75rem; font-weight:600;">
                                    @item.AirlineCode
                                </span>
                            }
                            else { <span>—</span> }
                        </td>
                        <td>
                            @{
                                var sc = item.Status == "ACTIVE" ? "#10B981" : "#EF4444";
                                var si = item.Status == "ACTIVE" ? "bi-circle-fill" : "bi-circle";
                            }
                            <span style="color:@sc; font-size:.8rem; font-weight:600;">
                                <i class="bi @si me-1" style="font-size:.5rem;"></i>@item.Status
                            </span>
                        </td>
                        <td class="text-end">
                            <button class="btn-edit" onclick="openEditModal(@item.Id,'@item.Username','@item.Role','@(item.AirlineCode??"")', '@item.Status')">
                                <i class="bi bi-pencil-fill me-1"></i>Edit
                            </button>
                            @if (item.Id > 1)
                            {
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" id="del-usr-@item.Id">
                                    <button type="button" class="btn-delete"
                                            onclick="confirmDelete('del-usr-@item.Id','Delete user &quot;@item.Username&quot;?')">
                                        <i class="bi bi-trash-fill me-1"></i>Delete
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5">
                        <div class="empty-state"><i class="bi bi-people"></i><p>No users found.</p></div>
                    </td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add User Modal -->
<div id="addModal" class="modal-overlay" onclick="if(event.target===this)this.classList.remove('show')">
    <div class="modal-box">
        <div class="modal-title"><i class="bi bi-person-plus-fill"></i>Add User</div>
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label class="form-label-fids">Username <span class="required-star">*</span></label>
                <input type="text" name="Username" class="form-control-fids" placeholder="e.g. tg_operator" required />
            </div>
            <div class="mb-3">
                <label class="form-label-fids">Password <span class="required-star">*</span></label>
                <input type="password" name="password" class="form-control-fids" placeholder="Min 6 characters" required />
            </div>
            <div class="mb-3">
                <label class="form-label-fids">Role <span class="required-star">*</span></label>
                <select name="Role" id="add-role" class="filter-select" style="width:100%;" onchange="toggleAirlineField('add-airline-wrap', this.value)" required>
                    <option value="">— Select Role —</option>
                    <option value="@Roles.Admin">ADMIN — Full access</option>
                    <option value="@Roles.Staff">STAFF — Manage flights</option>
                    <option value="@Roles.Airline">AIRLINE — View own flights only</option>
                </select>
            </div>
            <div id="add-airline-wrap" class="mb-4" style="display:none;">
                <label class="form-label-fids">Airline Code <span class="required-star">*</span></label>
                <select name="AirlineCode" class="filter-select" style="width:100%;">
                    <option value="">— Select Airline —</option>
                    @foreach (var a in airlines)
                    {
                        <option value="@a.IATACode">@a.IATACode — @a.AirlineName</option>
                    }
                </select>
            </div>
            <div class="d-flex justify-content-end gap-3">
                <button type="button" class="btn-cancel" onclick="document.getElementById('addModal').classList.remove('show')">Cancel</button>
                <button type="submit" class="btn-save"><i class="bi bi-plus-lg me-1"></i>Add</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit User Modal -->
<div id="editModal" class="modal-overlay" onclick="if(event.target===this)this.classList.remove('show')">
    <div class="modal-box">
        <div class="modal-title"><i class="bi bi-pencil-fill"></i>Edit User</div>
        <form asp-action="Edit" method="post">
            <input type="hidden" name="Id" id="edit-id" />
            <div class="mb-3">
                <label class="form-label-fids">Username</label>
                <input type="text" name="Username" id="edit-username" class="form-control-fids" readonly
                       style="opacity:.5; cursor:not-allowed;" />
            </div>
            <div class="mb-3">
                <label class="form-label-fids">New Password <small style="color:#7e8299;">(leave blank to keep current)</small></label>
                <input type="password" name="newPassword" class="form-control-fids" placeholder="Leave blank to keep" />
            </div>
            <div class="mb-3">
                <label class="form-label-fids">Role</label>
                <select name="Role" id="edit-role" class="filter-select" style="width:100%;"
                        onchange="toggleAirlineField('edit-airline-wrap', this.value)">
                    <option value="@Roles.Admin">ADMIN — Full access</option>
                    <option value="@Roles.Staff">STAFF — Manage flights</option>
                    <option value="@Roles.Airline">AIRLINE — View own flights only</option>
                </select>
            </div>
            <div id="edit-airline-wrap" class="mb-3" style="display:none;">
                <label class="form-label-fids">Airline Code</label>
                <select name="AirlineCode" id="edit-airline" class="filter-select" style="width:100%;">
                    <option value="">— Select Airline —</option>
                    @foreach (var a in airlines)
                    {
                        <option value="@a.IATACode">@a.IATACode — @a.AirlineName</option>
                    }
                </select>
            </div>
            <div class="mb-4">
                <label class="form-label-fids">Status</label>
                <select name="Status" id="edit-status" class="filter-select" style="width:100%;">
                    <option value="ACTIVE">ACTIVE</option>
                    <option value="INACTIVE">INACTIVE</option>
                </select>
            </div>
            <div class="d-flex justify-content-end gap-3">
                <button type="button" class="btn-cancel" onclick="document.getElementById('editModal').classList.remove('show')">Cancel</button>
                <button type="submit" class="btn-save"><i class="bi bi-save me-1"></i>Save</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function openAddModal() {
    document.getElementById('addModal').classList.add('show');
}

function openEditModal(id, username, role, airlineCode, status) {
    document.getElementById('edit-id').value      = id;
    document.getElementById('edit-username').value = username;
    document.getElementById('edit-role').value    = role;
    document.getElementById('edit-status').value  = status;
    document.getElementById('edit-airline').value = airlineCode;
    toggleAirlineField('edit-airline-wrap', role);
    document.getElementById('editModal').classList.add('show');
}

function toggleAirlineField(wrapId, role) {
    document.getElementById(wrapId).style.display = (role === '@Roles.Airline') ? 'block' : 'none';
}
</script>
}
