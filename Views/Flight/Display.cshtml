@model IEnumerable<FidsSystem.Models.Flight>
@{
    Layout = null;
    bool isArrival = ViewBag.Type == "Arrival";
    string orient  = ViewBag.Orient ?? "h";
    string airportTH = ViewBag.AirportNameTH ?? "ท่าอากาศยานนานาชาติ";
    string airportEN = ViewBag.AirportNameEN ?? "International Airport";
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(isArrival ? "ข้อมูลเที่ยวบินขาเข้า" : "ข้อมูลเที่ยวบินขาออก")</title>
    <link rel="stylesheet" href="~/display/css/departure.css" />
</head>
<body>
    <div class="container" data-orient="@orient">

        <!-- TOP HEADER -->
        <div class="header">
            <div class="header-left">
                <svg class="header-plane" viewBox="0 0 24 24">
                    <path d="M21,16V14L13,9V3.5A1.5,1.5 0 0,0 11.5,2A1.5,1.5 0 0,0 10,3.5V9L2,14V16L10,13.5V19L8,20.5V22L11.5,21L15,22V20.5L13,19V13.5L21,16Z"/>
                </svg>
                <span class="header-title"
                      data-lang-key="@(isArrival ? "ARRIVALS" : "DEPARTURES")">
                    @(isArrival ? "ขาเข้า" : "ขาออก")
                </span>
            </div>
            <div class="header-right">
                <div class="airport-pill">
                    <div class="airport-icon">✈</div>
                    <div>
                        <div class="airport-th">@airportTH</div>
                        <div class="airport-en">@airportEN</div>
                    </div>
                </div>
                <div class="time-pill" id="current-time"></div>
                <div class="lang-badge" id="langBadge">TH</div>
            </div>
        </div>

        <!-- COLUMN HEADERS -->
        <div class="col-header @(isArrival ? "arr-cols" : "dep-cols")">
            <div data-lang-key="flight">เที่ยวบิน</div>
            <div data-lang-key="airline">สายการบิน</div>
            <div data-lang-key="@(isArrival ? "origin" : "destination")">@(isArrival ? "ต้นทาง" : "ปลายทาง")</div>
            <div data-lang-key="time">เวลา</div>
            <div data-lang-key="@(isArrival ? "belt" : "gate")">@(isArrival ? "สายพาน" : "ประตู")</div>
            <div data-lang-key="remarks">หมายเหตุ</div>
        </div>

        <!-- FLIGHT BOARD -->
        <div class="flight-board">
            @foreach (var item in Model)
            {
                <div class="flight-row @(isArrival ? "arr-cols" : "dep-cols") @GetRowClass(item.Status)">
                    <div class="flight-number">@item.FlightNumber</div>
                    <div class="airline">
                        <span class="airline-logo @GetAirlineClass(item.Airline)">@(item.Airline ?? "-")</span>
                    </div>
                    <div class="from"
                         data-city="@(isArrival ? (item.Origin ?? "") : (item.Destination ?? ""))">
                        @(isArrival ? (item.Origin ?? "-") : (item.Destination ?? "-"))
                    </div>
                    <div class="time">@item.ScheduledTime.ToString("HH:mm")</div>
                    <div>
                        <span class="gate-badge">@(isArrival ? (item.Belt ?? "-") : (item.Gate ?? "-"))</span>
                    </div>
                    <div class="status @GetStatusClass(item.Status)"
                         data-status-key="@GetStatusKey(item.Status)">
                        @GetStatusText(item.Status)
                    </div>
                </div>
            }
            @if (!Model.Any())
            {
                <div class="flight-row @(isArrival ? "arr-cols" : "dep-cols")">
                    <div style="grid-column:1/-1; text-align:center; color:rgba(255,255,255,0.25); font-size:18px; padding:40px 0;">
                        ไม่มีข้อมูลเที่ยวบิน
                    </div>
                </div>
            }
        </div>

        <!-- FOOTER -->
        <div class="footer">
            <div class="footer-text">
                <div class="footer-content">
                    <svg class="plane-icon" viewBox="0 0 24 24">
                        <path d="M21,16V14L13,9V3.5A1.5,1.5 0 0,0 11.5,2A1.5,1.5 0 0,0 10,3.5V9L2,14V16L10,13.5V19L8,20.5V22L11.5,21L15,22V20.5L13,19V13.5L21,16Z"/>
                    </svg>
                    <span data-lang-key="@(isArrival ? "arr" : "dep")">
                        @(isArrival ? "เที่ยวบินขาเข้า • FLIGHT ARRIVALS • 到达航班 •" : "เที่ยวบินขาออก • FLIGHT DEPARTURES • 出发航班 •")
                    </span>
                </div>
            </div>
            <div class="footer-time">
                <span class="current-time" id="footer-time"></span>
            </div>
        </div>

    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/display/js/lang.js"></script>
    <script>
        // SignalR real-time refresh
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/flight")
            .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
            .build();

        connection.on("FlightUpdated", () => {
            setTimeout(() => location.reload(), 500);
        });

        connection.start().catch(err => console.warn("SignalR:", err));

        // Heartbeat every 30s
        const _screenKey = "@(isArrival ? "arrival" : "departure")-board";
        setInterval(() => {
            fetch('/Screen/Heartbeat', { method:'POST', headers:{'Content-Type':'application/json'},
                body: JSON.stringify({ screenKey: _screenKey }) }).catch(() => {});
        }, 30000);

        function updateTime() {
            const now = new Date();
            const thaiMonths = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
            const d  = now.getDate();
            const mo = thaiMonths[now.getMonth()];
            const y  = now.getFullYear() + 543;
            const h  = String(now.getHours()).padStart(2,'0');
            const mi = String(now.getMinutes()).padStart(2,'0');
            const txt = `${d} ${mo} ${y} | ${h}:${mi} น.`;
            const el1 = document.getElementById('current-time');
            const el2 = document.getElementById('footer-time');
            if (el1) el1.textContent = txt;
            if (el2) el2.textContent = txt;
        }
        updateTime();
        setInterval(updateTime, 1000);
    </script>
</body>
</html>

@functions {
    string GetAirlineClass(string? airline) {
        if (string.IsNullOrEmpty(airline)) return "";
        var a = airline.ToLower();
        if (a.Contains("airasia") || a.Contains("air asia")) return "air-asia";
        if (a.Contains("nok")) return "nok-air";
        if (a.Contains("lion")) return "lion-air";
        if (a.Contains("vietjet")) return "vietjet";
        return "";
    }

    // Normalize status → canonical key (used as data-status-key in JS)
    string GetStatusKey(string? status) {
        if (string.IsNullOrEmpty(status)) return "";
        return status.ToUpper().Trim() switch {
            "CHECK-IN OPEN"  or "เปิดให้เช็คอิน"          => "CHECKIN_OPEN",
            "BOARDING"       or "กำลังขึ้นเครื่อง"
                             or "ลงทะเบียนรับบัตรที่นั่ง"  => "BOARDING",
            "GATE OPEN"      or "ประตูเปิด"                 => "GATE_OPEN",
            "FINAL CALL"                                   => "FINAL_CALL",
            "DELAYED"        or "ล่าช้า"                    => "DELAYED",
            "CANCELLED"      or "ยกเลิก"                   => "CANCELLED",
            "LANDED"         or "ลงจอดแล้ว"                => "LANDED",
            "BAGGAGE"        or "รับสัมภาระ"
                             or "BAGGAGE CLAIM"             => "BAGGAGE",
            "EXPECTED"       or "คาดว่าจะถึง"              => "EXPECTED",
            "DEPARTED"       or "ออกเดินทางแล้ว"           => "DEPARTED",
            "ON TIME"        or "ตรงเวลา"                   => "ON_TIME",
            _ => ""
        };
    }

    // Initial display text (Thai) — JS will swap on cycle
    string GetStatusText(string? status) {
        var key = GetStatusKey(status);
        return key switch {
            "CHECKIN_OPEN" => "เปิดให้เช็คอิน",
            "BOARDING"     => "กำลังขึ้นเครื่อง",
            "FINAL_CALL"   => "Final Call",
            "GATE_OPEN"    => "ประตูเปิด",
            "ON_TIME"      => "ตรงเวลา",
            "DELAYED"      => "ล่าช้า",
            "CANCELLED"    => "ยกเลิก",
            "LANDED"       => "ลงจอดแล้ว",
            "BAGGAGE"      => "รับสัมภาระ",
            "EXPECTED"     => "คาดว่าจะถึง",
            "DEPARTED"     => "ออกเดินทางแล้ว",
            _ => status ?? "-"
        };
    }

    string GetStatusClass(string? status) {
        if (string.IsNullOrEmpty(status)) return "s-default";
        return status.ToUpper().Trim() switch {
            "CHECK-IN OPEN"  or "เปิดให้เช็คอิน"                    => "s-checkin",
            "BOARDING"       or "กำลังขึ้นเครื่อง"
                             or "ลงทะเบียนรับบัตรที่นั่ง"             => "s-boarding",
            "FINAL CALL"                                              => "s-finalcall",
            "GATE OPEN"      or "ประตูเปิด"                           => "s-gateopen",
            "ON TIME"        or "ตรงเวลา"                             => "s-ontime",
            "DELAYED"        or "ล่าช้า"                              => "s-delayed",
            "CANCELLED"      or "ยกเลิก"                             => "s-cancelled",
            "DEPARTED"       or "ออกเดินทางแล้ว"                     => "s-departed",
            "LANDED"         or "ลงจอดแล้ว"                          => "s-landed",
            "BAGGAGE"        or "รับสัมภาระ"  or "BAGGAGE CLAIM"     => "s-baggage",
            "EXPECTED"       or "คาดว่าจะถึง"                        => "s-expected",
            _ => "s-default"
        };
    }

    string GetRowClass(string? status) {
        if (string.IsNullOrEmpty(status)) return "";
        return status.ToUpper().Trim() switch {
            "BOARDING"    or "กำลังขึ้นเครื่อง"
                          or "ลงทะเบียนรับบัตรที่นั่ง"  => "row-boarding",
            "FINAL CALL"                                  => "row-finalcall",
            "DELAYED"     or "ล่าช้า"                    => "row-delayed",
            "CANCELLED"   or "ยกเลิก"                   => "row-cancelled",
            "ON TIME"     or "ตรงเวลา"                   => "row-ontime",
            "LANDED"      or "ลงจอดแล้ว"                => "row-landed",
            _ => ""
        };
    }
}
