@model IEnumerable<FidsSystem.Models.AdPlaylist>
@{ ViewData["Title"] = "Playlists"; }

@section TopbarActions {
    <button class="btn-add" onclick="document.getElementById('addPlaylistModal').classList.add('show')">
        <i class="bi bi-plus-lg"></i> Add Playlist
    </button>
}

@if (TempData["Success"] != null)
{
    <div class="alert-success-inline">
        <i class="bi bi-check-circle-fill"></i>@TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert-error-inline">
        <i class="bi bi-x-circle-fill"></i>@TempData["Error"]
    </div>
}

<div class="card">
    <form method="get" class="filter-bar">
        <div class="filter-input-wrap" style="max-width:320px;">
            <i class="bi bi-search"></i>
            <input type="text" name="search" class="filter-input" placeholder="Search Playlists Name" value="@ViewBag.Search" />
        </div>
        <button type="submit" class="btn-search"><i class="bi bi-search me-1"></i>Search</button>
        <a asp-action="Playlists" class="btn-clear"><i class="bi bi-x me-1"></i>Clear</a>
    </form>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th style="width:40%;">Playlists Name</th>
                    <th style="width:30%;">Media</th>
                    <th style="width:10%;">Total</th>
                    <th style="width:20%; text-align:right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-600" style="color:#0095ff;">@item.Name</td>
                        <td>
                            <div class="media-count">
                                @if (item.ImageCount > 0)
                                {
                                    <span class="media-item"><i class="bi bi-image"></i> @item.ImageCount</span>
                                }
                                @if (item.VideoCount > 0)
                                {
                                    <span class="media-item"><i class="bi bi-play-circle"></i> @item.VideoCount</span>
                                }
                            </div>
                        </td>
                        <td style="color:#7e8299;">@item.TotalCount</td>
                        <td class="text-end">
                            <a href="#" class="btn-edit">
                                <i class="bi bi-pencil-fill"></i> Edit
                            </a>
                            <form asp-action="DeletePlaylist" asp-route-id="@item.Id" method="post" class="d-inline" id="del-pl-@item.Id">
                                <button type="button" class="btn-delete"
                                        onclick="confirmDelete('del-pl-@item.Id','Delete playlist &quot;@item.Name&quot;?')">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4">
                            <div class="empty-state">
                                <i class="bi bi-collection-play"></i>
                                <p>No playlists found. Click <strong>+ Add Playlist</strong> to create one.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Any())
    {
        <div class="pagination-bar">
            <button class="page-btn"><i class="bi bi-chevron-left" style="font-size:.75rem;"></i></button>
            <button class="page-btn active">1</button>
            <button class="page-btn"><i class="bi bi-chevron-right" style="font-size:.75rem;"></i></button>
        </div>
    }
</div>

<!-- Add Playlist Modal -->
<div id="addPlaylistModal" class="modal-overlay" onclick="if(event.target===this)this.classList.remove('show')">
    <div class="modal-box">
        <div class="modal-title">
            <i class="bi bi-collection-play-fill"></i>Add Playlist
        </div>
        <form asp-action="CreatePlaylist" method="post">
            <div class="mb-4">
                <label class="form-label-fids">Playlist Name <span class="required-star">*</span></label>
                <input type="text" name="name" class="form-control-fids" placeholder="e.g. BC Playlist" required />
            </div>
            <div class="d-flex justify-content-end gap-3">
                <button type="button" class="btn-cancel" onclick="document.getElementById('addPlaylistModal').classList.remove('show')">Cancel</button>
                <button type="submit" class="btn-save"><i class="bi bi-plus-lg me-1"></i>Add</button>
            </div>
        </form>
    </div>
</div>
